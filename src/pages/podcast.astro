---
import Layout from '../layouts/Layout.astro'
import Kicker from '../components/Kicker.astro'
import TbcMark from '../components/TbcMark.astro'
import Keycap from '../components/Keycap.astro'
import { episodes, CONTACT_EMAIL, YOUTUBE_URL } from '../data'

const rowBase =
  'group grid grid-cols-[auto_1fr_auto] items-center gap-x-5 rounded-[16px] border border-line bg-bg px-6 py-5 shadow-[var(--shadow-card)] transition-all'

const SITE = 'https://talkbeyondcode.com'
const schema = [
  {
    '@type': 'PodcastSeries',
    '@id': `${SITE}/podcast#series`,
    name: 'Ctrl+Shift+AI',
    url: `${SITE}/podcast`,
    description:
      'A weekly podcast where four working engineers talk to guests about how they actually use AI in their day-to-day engineering work.',
    webFeed: `${SITE}/rss.xml`,
    publisher: { '@id': `${SITE}/#organization` },
  },
  {
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is Ctrl+Shift+AI?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Ctrl+Shift+AI is TalkBeyondCode’s weekly podcast. Four working engineers talk to a guest about how they really use AI in their day-to-day engineering work, across stacks and career stages.',
        },
      },
      {
        '@type': 'Question',
        name: 'Where can I watch Ctrl+Shift+AI?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Every episode is on the TalkBeyondCode YouTube channel, with new episodes weekly.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I come on the podcast?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Email talkbeyondcode@gmail.com. Any stack, any level. We want the unpolished version.',
        },
      },
    ],
  },
]
---
<Layout
  title="Podcast · Ctrl+Shift+AI · TalkBeyondCode"
  description="Ctrl+Shift+AI: conversations with engineers across career stages and stacks about how they actually adopt AI in their day-to-day work. New episodes weekly on YouTube."
  schema={schema}
>
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-20">
    {/* hero */}
    <div class="grid items-center gap-12 md:grid-cols-[0.85fr_1.15fr]">
      <div class="order-2 rounded-[24px] border border-line bg-surface p-10 text-center md:order-1">
        <div class="mb-6 flex justify-center">
          <TbcMark id="pod" size={48} />
        </div>
        <div class="flex items-center justify-center gap-2.5">
          <Keycap size="sm">Ctrl</Keycap>
          <Keycap size="sm">Shift</Keycap>
          <Keycap size="sm" gradient>AI</Keycap>
        </div>
        <p class="mt-6 font-display text-2xl font-bold text-ink">Ctrl+Shift+AI</p>
        <p class="mt-1 font-mono text-xs uppercase tracking-[0.14em] text-muted">
          how real engineers ship with AI
        </p>
      </div>

      <div class="order-1 md:order-2">
        <Kicker>THE PODCAST · SEASON 01</Kicker>
        <h1 class="mt-4 text-[clamp(2.4rem,6vw,4rem)] font-bold leading-[1.02] tracking-tight text-ink">
          Ctrl<span class="grad-text">+Shift+AI</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg text-muted">
          We talk to engineers at every career stage and on every kind of stack about
          how they actually use AI in their day-to-day work.
        </p>
        <p class="mt-5 font-mono text-xs uppercase tracking-[0.12em] text-muted">
          Watch on YouTube
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a
            href={YOUTUBE_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
          >
            Follow the podcast
          </a>
          <span class="font-mono text-xs tracking-[0.08em] text-muted">new episodes weekly</span>
        </div>
      </div>
    </div>

    {/* episodes */}
    <section class="py-16">
      <Kicker>EPISODES</Kicker>
      <h2 class="mt-3 text-[clamp(1.7rem,3.4vw,2.5rem)] font-bold tracking-tight text-ink">
        Episodes
      </h2>
      <ul class="mt-8 space-y-4">
        {
          episodes.map((ep) => {
            const body = (
              <Fragment>
                <span class="rounded-[10px] border border-line bg-panel px-3 py-2 font-mono text-base font-bold tabular-nums text-ink">
                  {ep.n}
                </span>
                <div>
                  <div class="flex flex-wrap items-center gap-2.5">
                    {ep.live && (
                      <span class="inline-flex items-center rounded-full bg-gradient-to-r from-brand-cyan via-brand-violet to-brand-magenta px-2.5 py-0.5 font-mono text-[0.6rem] font-bold uppercase tracking-[0.16em] text-white">
                        New
                      </span>
                    )}
                    <h3 class:list={['text-base font-bold tracking-tight text-ink md:text-lg', ep.live && 'transition-colors group-hover:text-primary']}>
                      {ep.title}
                    </h3>
                  </div>
                  <p class="mt-1 font-mono text-xs tracking-[0.06em] text-muted">{ep.meta}</p>
                </div>
                <div class="flex items-center gap-4">
                  <span class:list={['hidden font-mono text-[0.7rem] font-bold uppercase tracking-[0.12em] sm:inline', ep.live ? 'text-primary' : 'text-muted']}>
                    {ep.status}
                  </span>
                  <span
                    class:list={['flex h-10 w-10 items-center justify-center rounded-full text-sm', ep.live ? 'bg-primary text-white' : 'border border-line text-muted']}
                    aria-hidden="true"
                  >
                    ▶
                  </span>
                </div>
              </Fragment>
            )
            return (
              <li>
                {ep.live ? (
                  <a href={ep.href} target="_blank" rel="noreferrer" class={`${rowBase} hover:-translate-y-0.5 hover:shadow-[var(--shadow-card-hover)]`}>
                    {body}
                  </a>
                ) : (
                  <div class={rowBase}>{body}</div>
                )}
              </li>
            )
          })
        }
      </ul>
    </section>

    {/* be a guest */}
    <section class="flex flex-col items-start justify-between gap-6 rounded-[24px] border border-line bg-surface p-8 sm:flex-row sm:items-center md:p-10">
      <div>
        <h2 class="max-w-lg text-xl font-bold tracking-tight text-ink">
          Using AI in your work in a way nobody talks about?
        </h2>
        <p class="mt-2 text-sm text-muted">
          Any stack, any level. We want the unpolished version.
        </p>
      </div>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="shrink-0 rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
      >
        Pitch yourself →
      </a>
    </section>
  </div>
</Layout>
