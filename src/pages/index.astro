---
import Layout from '../layouts/Layout.astro'
import SectionHead from '../components/SectionHead.astro'
import Kicker from '../components/Kicker.astro'
import TbcMark from '../components/TbcMark.astro'
import Keycap from '../components/Keycap.astro'
import Newsletter from '../components/Newsletter.astro'
import { getCollection, getEntry } from 'astro:content'
import { signal, creators, episodes } from '../data'

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })

const sortedArticles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) =>
    Number(b.data.featured) - Number(a.data.featured) || b.data.date.getTime() - a.data.date.getTime(),
)
const latestArticles = await Promise.all(
  sortedArticles.slice(0, 3).map(async (entry) => ({ entry, author: (await getEntry(entry.data.author))!.data })),
)

// "Fresh from the channel" is a real, live feed: the current live episode(s)
// first, then the newest articles filling the remaining slots.
const dropEpisodes = episodes
  .filter((e) => e.live)
  .map((e) => ({
    kind: 'Podcast',
    date: 'New',
    keycaps: true,
    title: e.title,
    blurb: e.meta,
    cta: 'Watch',
    to: e.href ?? '/podcast',
  }))
const dropArticles = sortedArticles.slice(0, Math.max(0, 3 - dropEpisodes.length)).map((entry) => ({
  kind: 'Article',
  date: fmt(entry.data.date),
  keycaps: false,
  title: entry.data.title,
  blurb: entry.data.excerpt,
  cta: 'Read',
  to: `/articles/${entry.id}`,
}))
const drops = [...dropEpisodes, ...dropArticles].slice(0, 3)
---
<Layout
  title="TalkBeyondCode: Engineering conversations beyond the code"
  description="Four working engineers on what we’re building and breaking, plus honest conversations about how AI is changing the way we ship. Home of the Ctrl+Shift+AI podcast."
>
  {/* announcement bar */}
  <div class="relative bg-lav" data-banner>
    <a
      href="/podcast"
      class="block px-10 py-3.5 text-center font-mono text-[0.82rem] tracking-[0.02em] text-primary-deep transition-opacity hover:opacity-80"
    >
      NEW · Ctrl+Shift+AI: our podcast on how engineers ship with AI → Listen
    </a>
    <button
      type="button"
      data-banner-close
      aria-label="Dismiss announcement"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-muted transition-colors hover:text-ink"
    >
      ✕
    </button>
  </div>

  {/* hero */}
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[radial-gradient(circle,rgba(139,92,246,0.18),rgba(34,211,238,0.10)_45%,transparent_70%)] blur-[10px]"
    >
    </div>
    <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-6 py-14 md:grid-cols-[1.15fr_0.85fr] md:px-10 md:py-28">
      <div>
        <div data-hero><Kicker>FOUR ENGINEERS · ONE CHANNEL</Kicker></div>
        <h1 data-hero class="mt-5 text-[clamp(2.6rem,6vw,4rem)] font-bold leading-[1.04] tracking-[-0.02em] text-ink">
          Engineering conversations<br /><span class="grad-text">beyond the code.</span>
        </h1>
        <p data-hero class="mt-6 max-w-xl text-lg text-muted">
          Real engineering conversations about building software, solving problems, and adapting to the AI era.
        </p>
        <div data-hero class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/podcast"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
          >
            <span aria-hidden="true">▶</span> Listen to the podcast
          </a>
          <a
            href="/articles"
            class="inline-flex items-center rounded-full border border-line px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-ink transition-colors hover:border-primary hover:text-primary"
          >
            Read the articles
          </a>
        </div>
      </div>

      {/* the nav already carries the logo on mobile; showing it again here reads
          as two logos stacked, so the hero visual is md-and-up only. The
          waveform bars inside the mark animate as a live equalizer — one mark,
          no separate wave. */}
      <div data-hero class="hidden md:flex md:justify-end">
        <TbcMark id="hero" size={200} animated class="h-auto w-[clamp(180px,22vw,320px)]" />
      </div>
    </div>
  </section>

  {/* fresh from the channel */}
  <section class="mx-auto max-w-6xl px-6 py-20 md:px-10">
    <SectionHead kicker="LATEST DROPS" title="Fresh from the channel" />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        drops.map((d) => (
          <a
            href={d.to}
            class="group flex flex-col rounded-[20px] border border-line bg-bg p-7 shadow-[var(--shadow-card)] transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-primary">{d.kind}</span>
              <span class="font-mono text-[0.7rem] tracking-[0.12em] text-muted">{d.date}</span>
            </div>
            {d.keycaps && (
              <div class="mt-6 flex gap-2.5">
                <Keycap size="sm">Ctrl</Keycap>
                <Keycap size="sm">Shift</Keycap>
                <Keycap size="sm" gradient>AI</Keycap>
              </div>
            )}
            <h3 class="mt-6 text-xl font-bold leading-snug tracking-tight text-ink">{d.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{d.blurb}</p>
            <span class="mt-auto pt-6 font-mono text-sm font-medium tracking-[0.05em] text-primary transition-transform group-hover:translate-x-1">
              {d.cta} →
            </span>
          </a>
        ))
      }
    </div>
  </section>

  {/* podcast band */}
  <section class="border-y border-line bg-surface">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 md:grid-cols-[0.9fr_1.1fr] md:px-10">
      <div class="rounded-[24px] border border-line bg-bg p-10 text-center shadow-[var(--shadow-card)]">
        <div class="mb-6 flex justify-center"><TbcMark id="band" size={48} /></div>
        <div class="flex items-center justify-center gap-2.5">
          <Keycap size="sm">Ctrl</Keycap>
          <Keycap size="sm">Shift</Keycap>
          <Keycap size="sm" gradient>AI</Keycap>
        </div>
        <p class="mt-6 font-display text-xl font-bold text-ink">Ctrl+Shift+AI</p>
        <p class="mt-1 font-mono text-xs uppercase tracking-[0.14em] text-muted">how real engineers ship with AI</p>
      </div>

      <div>
        <Kicker>THE PODCAST</Kicker>
        <h2 class="mt-3 text-[clamp(2rem,4.5vw,3rem)] font-bold tracking-tight text-ink">Ctrl+Shift+AI</h2>
        <p class="mt-4 max-w-md text-muted">
          Every week we sit down with one engineer, anywhere from junior to staff-plus
          and on any stack, and get into how AI actually fits their real workflow. We skip
          the hype and ask what they really do.
        </p>
        <p class="mt-5 font-mono text-xs uppercase tracking-[0.12em] text-muted">
          Watch on YouTube
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a
            href="/podcast"
            class="inline-flex items-center rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
          >
            Browse episodes →
          </a>
          <span class="font-mono text-xs tracking-[0.08em] text-muted">new episodes weekly</span>
        </div>
      </div>
    </div>
  </section>

  {/* from the blog */}
  <section class="mx-auto max-w-6xl px-6 py-20 md:px-10">
    <SectionHead kicker="WRITING" title="Latest writing" href="/articles" hrefLabel="All articles" />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        latestArticles.map(({ entry, author }) => (
          <a
            href={`/articles/${entry.id}`}
            class="group flex flex-col overflow-hidden rounded-[20px] border border-line bg-bg shadow-[var(--shadow-card)] transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
          >
            {entry.data.coverImage ? (
              <img src={entry.data.coverImage} alt={entry.data.title} class="h-36 w-full object-cover" />
            ) : (
              <div class="flex h-36 items-center justify-center bg-lav font-mono text-2xl font-bold text-primary/70">&lt;/&gt;</div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-primary">{entry.data.category}</span>
              <h3 class="mt-3 text-lg font-bold leading-snug tracking-tight text-ink">{entry.data.title}</h3>
              <span class="mt-auto pt-6 font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted">
                {author.name} · {entry.data.readingTime}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {/* four engineers */}
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-6xl px-6 py-16 md:px-10">
      <SectionHead kicker="THE HUMANS" title="Four engineers, one mic" href="/creators" hrefLabel="Meet the creators" />
      <div class="mt-8 grid grid-cols-1 gap-3 rounded-[20px] border border-line bg-bg p-4 shadow-[var(--shadow-card)] sm:grid-cols-2 lg:grid-cols-4 md:p-5">
        {
          creators.map((c) => (
            <a
              href="/creators"
              class="flex min-w-0 items-center gap-3 rounded-[14px] p-3 transition-colors hover:bg-surface"
            >
              <img
                src={c.photo}
                alt={c.name}
                loading="lazy"
                width="44"
                height="44"
                class="h-11 w-11 shrink-0 rounded-full border border-line object-cover"
              />
              <span class="min-w-0">
                <span class="block truncate font-mono text-sm font-bold tracking-tight text-ink">{c.name}</span>
                <span class="block truncate text-xs text-muted">{c.focus}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {/* what we're tracking */}
  <section class="mx-auto max-w-6xl px-6 py-20 md:px-10">
    <SectionHead kicker="SIGNAL" title="What we’re tracking" href="/signal" hrefLabel="All signal" />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        signal.slice(0, 3).map((s) => (
          <a
            href="/signal"
            class="flex flex-col rounded-[20px] border border-line bg-bg p-6 shadow-[var(--shadow-card)] transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
          >
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-primary">
              {s.kind} · {s.tag}
            </span>
            <h3 class="mt-3 text-base font-bold leading-snug tracking-tight text-ink">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{s.body}</p>
            {s.source && <span class="mt-auto pt-5 font-mono text-xs text-primary">{s.source.label} →</span>}
          </a>
        ))
      }
    </div>
  </section>

  {/* newsletter */}
  <section class="mx-auto max-w-6xl px-6 pb-24 md:px-10">
    <Newsletter />
  </section>
</Layout>

<script>
  import gsap from 'gsap'

  function initHome() {
    // dismissible announcement
    const close = document.querySelector('[data-banner-close]')
    close?.addEventListener('click', () => document.querySelector('[data-banner]')?.remove())

    if (!document.querySelector('[data-hero]')) return
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduce) return

    gsap.from('[data-hero]', {
      y: 22,
      opacity: 0,
      duration: 1,
      ease: 'expo.out',
      stagger: 0.08,
      delay: 0.05,
    })
    // the three waveform bars inside the hero logo move through a shared set
    // of equalizer "poses". All bars share the same duration and keyframe
    // count, so each column below is one coherent pose the trio strikes
    // together. Pose index 1 is the peaked-center silhouette — both outer
    // bars well below the tall middle bar, the logo's signature shape — so the
    // loop always resolves through it. First pose === last for a seamless cycle.
    const bars = gsap.utils.toArray<SVGElement>('[data-wave-bar]')
    //                pose:  0     1     2     3     4     5(=0)
    const poses = [
      /* left  (56) */ [0.7, 0.4, 0.95, 0.55, 0.8, 0.7],
      /* middle(76) */ [0.85, 1.0, 0.6, 0.9, 0.5, 0.85],
      /* right (96) */ [0.7, 0.4, 0.8, 1.0, 0.55, 0.7],
    ]
    // scale each bar about the shared vertical centerline (y=52 in the 152x104
    // viewBox) so it grows/shrinks symmetrically and stays vertically centered.
    // svgOrigin uses user-space coords — reliable even for zero-width line paths.
    const originX = [56, 76, 96]
    bars.forEach((bar, i) => {
      gsap.to(bar, {
        keyframes: { scaleY: poses[i], ease: 'sine.inOut' },
        svgOrigin: `${originX[i]} 52`,
        duration: 4,
        repeat: -1,
      })
    })
  }

  document.addEventListener('astro:page-load', initHome)
</script>
