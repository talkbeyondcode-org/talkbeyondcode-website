---
import Layout from '../layouts/Layout.astro'
import PageHeader from '../components/PageHeader.astro'
import Newsletter from '../components/Newsletter.astro'
import { articles, articleCategories, featuredArticle } from '../data'
---
<Layout
  title="Articles · TalkBeyondCode"
  description="Long-form from four working engineers — what we’re building, breaking and rethinking as AI reshapes the day-to-day."
>
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-20">
    <PageHeader
      kicker="WRITING"
      title="Notes beyond the code"
      intro="Long-form from the four of us — what we’re building, breaking and rethinking as AI reshapes the day-to-day."
    />

    {/* filters */}
    <div class="mt-8 flex flex-wrap gap-2.5" data-filters>
      {
        articleCategories.map((cat) => (
          <button
            type="button"
            data-filter={cat}
            class="filter-chip rounded-full border px-4 py-1.5 font-mono text-xs tracking-[0.06em] transition-colors"
          >
            {cat}
          </button>
        ))
      }
    </div>

    {/* featured */}
    <article
      data-category={featuredArticle.category}
      class="group mt-10 grid cursor-pointer overflow-hidden rounded-[24px] border border-line bg-bg shadow-[var(--shadow-card)] transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)] md:grid-cols-[1fr_1.2fr]"
    >
      <div class="flex min-h-[220px] items-center justify-center bg-lav font-mono text-4xl font-bold text-primary/70">&lt;/&gt;</div>
      <div class="flex flex-col justify-center p-8 md:p-10">
        <span class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-primary">
          Featured · {featuredArticle.category}
        </span>
        <h2 class="mt-4 text-[clamp(1.5rem,3vw,2.1rem)] font-bold leading-tight tracking-tight text-ink">
          {featuredArticle.title}
        </h2>
        <p class="mt-4 max-w-xl text-muted">{featuredArticle.excerpt}</p>
        <span class="mt-6 font-mono text-[0.72rem] uppercase tracking-[0.12em] text-muted">
          {featuredArticle.author} · {featuredArticle.read} · {featuredArticle.date}
        </span>
      </div>
    </article>

    {/* grid */}
    <div class="mt-6 grid gap-6 md:grid-cols-3" data-grid>
      {
        articles.map((a) => (
          <article
            data-category={a.category}
            class="group flex cursor-pointer flex-col overflow-hidden rounded-[20px] border border-line bg-bg shadow-[var(--shadow-card)] transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
          >
            <div class="flex h-36 items-center justify-center bg-lav font-mono text-2xl font-bold text-primary/70">&lt;/&gt;</div>
            <div class="flex flex-1 flex-col p-6">
              <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-primary">{a.category}</span>
              <h3 class="mt-3 text-lg font-bold leading-snug tracking-tight text-ink">{a.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{a.excerpt}</p>
              <span class="mt-auto pt-6 font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted">
                {a.author} · {a.read}
              </span>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-16">
      <Newsletter />
    </div>
  </div>
</Layout>

<script>
  const ACTIVE = ['border-primary', 'bg-primary', 'text-white']
  const IDLE = ['border-line', 'bg-bg', 'text-muted', 'hover:border-primary', 'hover:text-primary']
  const chips = [...document.querySelectorAll<HTMLButtonElement>('.filter-chip')]
  const cards = [...document.querySelectorAll<HTMLElement>('[data-category]')]

  function setActive(chip: HTMLButtonElement) {
    chips.forEach((c) => {
      const on = c === chip
      c.classList.toggle('is-active', on)
      ;(on ? ACTIVE : IDLE).forEach((cls) => c.classList.add(cls))
      ;(on ? IDLE : ACTIVE).forEach((cls) => c.classList.remove(cls))
    })
  }

  function applyFilter(filter: string) {
    cards.forEach((card) => {
      const show = filter === 'All' || card.dataset.category === filter
      card.toggleAttribute('hidden', !show)
    })
  }

  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      setActive(chip)
      applyFilter(chip.dataset.filter || 'All')
    }),
  )

  // default: "All" active
  if (chips[0]) {
    setActive(chips[0])
    applyFilter('All')
  }
</script>
