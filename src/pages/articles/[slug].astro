---
import { getCollection, getEntry, render, type CollectionEntry } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Kicker from '../../components/Kicker.astro'
import Newsletter from '../../components/Newsletter.astro'

export async function getStaticPaths() {
  const entries = await getCollection('articles', ({ data }) => !data.draft)
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }))
}

interface Props {
  entry: CollectionEntry<'articles'>
}

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, excerpt, category, coverImage, date, readingTime } = entry.data
const author = (await getEntry(entry.data.author))!.data
const dateLabel = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })

const SITE = 'https://talkbeyondcode.com'
const url = `${SITE}/articles/${entry.id}`
const share = {
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
  x: `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`,
}

const socials = [
  { key: 'linkedin', href: author.linkedin, label: 'LinkedIn' },
  { key: 'twitter', href: author.twitter, label: 'X' },
  { key: 'github', href: author.github, label: 'GitHub' },
  { key: 'website', href: author.website, label: 'Website' },
].filter((s) => s.href)

const ICONS: Record<string, string> = {
  linkedin:
    '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>',
  twitter:
    '<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  github:
    '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  website:
    '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 3.5 6 3.5 9s-1 6.5-3.5 9c-2.5-2.5-3.5-6-3.5-9s1-6.5 3.5-9z"/></svg>',
}
const socialIcon = (key: string) => ICONS[key] ?? ''

const schema = [
  {
    '@type': 'BlogPosting',
    headline: title,
    description: excerpt,
    articleSection: category,
    datePublished: date.toISOString(),
    author: { '@type': 'Person', name: author.name, ...(author.linkedin ? { sameAs: [author.linkedin] } : {}) },
    publisher: { '@id': `${SITE}/#organization` },
    mainEntityOfPage: url,
  },
]
---
<Layout
  title={`${title} · TalkBeyondCode`}
  description={excerpt}
  ogType="article"
  ogImage={`/og/articles/${entry.id}.png`}
  schema={schema}
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <a
      href="/articles"
      class="font-mono text-xs font-bold uppercase tracking-[0.1em] text-primary transition-colors hover:text-primary-deep"
    >
      ← Articles
    </a>

    <div class="mt-8"><Kicker>{category}</Kicker></div>
    <h1 class="mt-4 text-[clamp(2rem,5vw,3rem)] font-bold leading-[1.08] tracking-tight text-ink">
      {title}
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-muted">{excerpt}</p>

    {/* byline */}
    <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-3 border-y border-line py-5">
      <div class="flex items-center gap-3">
        {author.avatar ? (
          <img
            src={author.avatar}
            alt={author.name}
            width="44"
            height="44"
            class="h-11 w-11 shrink-0 rounded-full border border-line object-cover"
          />
        ) : (
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-lav font-mono text-sm font-bold text-primary">
            {author.name.slice(0, 1)}
          </span>
        )}
        <div>
          <p class="text-sm font-bold tracking-tight text-ink">{author.name}</p>
          <p class="text-xs text-muted">{author.role}</p>
        </div>
      </div>

      {socials.length > 0 && (
        <div class="flex items-center gap-1.5">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noreferrer"
              aria-label={`${author.name} on ${s.label}`}
              class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-line text-muted transition-colors hover:border-primary hover:bg-primary hover:text-white"
            >
              <span set:html={socialIcon(s.key)} />
            </a>
          ))}
        </div>
      )}

      <span class="ml-auto font-mono text-[0.7rem] uppercase tracking-[0.12em] text-muted">
        {readingTime} · {dateLabel}
      </span>
    </div>

    {/* cover */}
    {coverImage ? (
      <img
        src={coverImage}
        alt={title}
        class="mt-10 aspect-[16/9] w-full rounded-[20px] border border-line object-cover"
      />
    ) : (
      <div class="mt-10 flex aspect-[16/9] items-center justify-center rounded-[20px] border border-line bg-lav font-mono text-5xl font-bold text-primary/60">
        &lt;/&gt;
      </div>
    )}

    <div class="prose mt-10">
      <Content />
    </div>

    {/* share */}
    <div class="mt-14 flex flex-wrap items-center gap-3 border-t border-line pt-8">
      <span class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.16em] text-muted">Share</span>
      <a
        href={share.linkedin}
        target="_blank"
        rel="noreferrer"
        aria-label="Share on LinkedIn"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition-colors hover:border-primary hover:bg-primary hover:text-white"
      >
        <span set:html={socialIcon('linkedin')} />
      </a>
      <a
        href={share.x}
        target="_blank"
        rel="noreferrer"
        aria-label="Share on X"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition-colors hover:border-primary hover:bg-primary hover:text-white"
      >
        <span set:html={socialIcon('twitter')} />
      </a>
      <button
        type="button"
        data-copy-link
        data-url={url}
        class="inline-flex items-center gap-2 rounded-full border border-line px-4 py-2 font-mono text-xs font-bold uppercase tracking-[0.1em] text-muted transition-colors hover:border-primary hover:text-primary"
      >
        <span data-copy-label>Copy link</span>
      </button>
    </div>

    <div class="mt-16">
      <Newsletter />
    </div>
  </article>
</Layout>

<script>
  function initCopyLink() {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
      const label = btn.querySelector<HTMLElement>('[data-copy-label]')
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url || window.location.href
        try {
          await navigator.clipboard.writeText(url)
        } catch {
          const t = document.createElement('textarea')
          t.value = url
          document.body.appendChild(t)
          t.select()
          document.execCommand('copy')
          t.remove()
        }
        if (label) {
          const prev = label.textContent
          label.textContent = 'Copied!'
          setTimeout(() => (label.textContent = prev), 1600)
        }
      })
    })
  }
  document.addEventListener('astro:page-load', initCopyLink)
</script>
