---
import Layout from '../layouts/Layout.astro'
import PageHeader from '../components/PageHeader.astro'
import { creators, CONTACT_EMAIL } from '../data'

const SITE = 'https://talkbeyondcode.com'
/* Gmail's old `?view=cm` compose URL now renders a blank page; `tf=cm` is the
   format Gmail currently accepts. */
const GMAIL_COMPOSE_URL = `https://mail.google.com/mail/u/0/?tf=cm&fs=1&to=${CONTACT_EMAIL}&su=${encodeURIComponent(
  'Collaboration with TalkBeyondCode',
)}`
const schema = creators.map((c) => ({
  '@type': 'Person',
  name: c.name,
  jobTitle: c.role,
  knowsAbout: c.talks,
  sameAs: [c.linkedin],
  worksFor: { '@id': `${SITE}/#organization` },
}))
---
<Layout
  title="Creators · TalkBeyondCode"
  description="The four engineers behind TalkBeyondCode. Different companies, stacks and career stages, one shared conversation about building software in the age of AI."
  schema={schema}
>
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-20">
    <PageHeader
      kicker="THE HUMANS"
      title="Four engineers, one mic"
      intro="We ship software at different companies, on different stacks, at different career stages. That friction is the whole point: same question, four very different answers."
    />

    {/* creators carousel */}
    <div class="mt-12" data-carousel>
      <div
        class="flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-4 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        data-carousel-track
      >
        {
          creators.map((c) => (
            <article class="flex w-[88%] shrink-0 snap-start flex-col gap-5 rounded-[20px] border border-line bg-bg p-7 shadow-[var(--shadow-card)] sm:w-[60%] md:p-8 lg:w-[calc(50%-0.75rem)]">
              <div class="flex items-center gap-4">
                <img
                  src={c.photo}
                  alt={c.name}
                  loading="lazy"
                  width="56"
                  height="56"
                  class="h-14 w-14 shrink-0 rounded-full border border-line object-cover"
                />
                <div>
                  <h2 class="text-xl font-bold tracking-tight text-ink">{c.name}</h2>
                  <p class="mt-0.5 text-sm text-muted">{c.role}</p>
                </div>
              </div>
              <p class="text-sm leading-relaxed text-muted">{c.bio}</p>
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-muted">Stack</span>
                  <div class="mt-2.5 flex flex-wrap gap-2">
                    {c.stack.map((t) => (
                      <span class="rounded-full border border-line bg-bg px-3 py-1 font-mono text-xs text-ink">{t}</span>
                    ))}
                  </div>
                </div>
                <div>
                  <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-muted">Talks about</span>
                  <div class="mt-2.5 flex flex-wrap gap-2">
                    {c.talks.map((t) => (
                      <span class="rounded-full border border-line bg-bg px-3 py-1 font-mono text-xs text-ink">{t}</span>
                    ))}
                  </div>
                </div>
              </div>
              <div class="mt-auto flex items-center justify-between border-t border-line pt-4">
                <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-muted">Connect</span>
                <a
                  href={c.linkedin}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`${c.name} on LinkedIn`}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition-colors hover:border-primary hover:bg-primary hover:text-white"
                >
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
                  </svg>
                </a>
              </div>
            </article>
          ))
        }
      </div>

      {/* carousel controls */}
      <div class="mt-5 flex items-center justify-between">
        <div class="flex gap-2" data-carousel-dots aria-hidden="true"></div>
        <div class="flex gap-2">
          <button
            type="button"
            data-carousel-prev
            aria-label="Previous creator"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line text-ink transition-colors hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-30"
          >
            ←
          </button>
          <button
            type="button"
            data-carousel-next
            aria-label="Next creator"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-line text-ink transition-colors hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-30"
          >
            →
          </button>
        </div>
      </div>
    </div>

    <section class="mt-16 flex flex-col items-start justify-between gap-6 rounded-[24px] border border-line bg-bg p-8 shadow-[var(--shadow-card)] sm:flex-row sm:items-center md:p-10">
      <h2 class="max-w-md text-xl font-bold tracking-tight text-ink">
        Want to collaborate?
      </h2>
      <a
        href={GMAIL_COMPOSE_URL}
        target="_blank"
        rel="noreferrer"
        class="shrink-0 rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
      >
        {CONTACT_EMAIL}
      </a>
    </section>
  </div>
</Layout>

<script>
  function initCreatorCarousel() {
    const root = document.querySelector<HTMLElement>('[data-carousel]')
    if (!root) return
    const track = root.querySelector<HTMLElement>('[data-carousel-track]')
    const dotsWrap = root.querySelector<HTMLElement>('[data-carousel-dots]')
    const prev = root.querySelector<HTMLButtonElement>('[data-carousel-prev]')
    const next = root.querySelector<HTMLButtonElement>('[data-carousel-next]')
    if (!track || !dotsWrap || !prev || !next) return

    const cards = [...track.children] as HTMLElement[]
    const step = () => (cards[1] ? cards[1].offsetLeft - cards[0].offsetLeft : cards[0].offsetWidth)

    // one dot per card
    const dots = cards.map((_, i) => {
      const b = document.createElement('button')
      b.type = 'button'
      b.setAttribute('aria-label', `Go to creator ${i + 1}`)
      b.className = 'h-2 w-2 rounded-full bg-line transition-colors'
      b.addEventListener('click', () => track.scrollTo({ left: step() * i, behavior: 'smooth' }))
      dotsWrap.appendChild(b)
      return b
    })

    function activeIndex() {
      return Math.round(track!.scrollLeft / step())
    }

    function sync() {
      const idx = activeIndex()
      dots.forEach((d, i) => d.classList.toggle('bg-primary', i === idx))
      dots.forEach((d, i) => d.classList.toggle('bg-line', i !== idx))
      const maxScroll = track!.scrollWidth - track!.clientWidth - 1
      prev!.disabled = track!.scrollLeft <= 1
      next!.disabled = track!.scrollLeft >= maxScroll
    }

    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }))
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }))
    track.addEventListener('scroll', sync, { passive: true })
    window.addEventListener('resize', sync)
    sync()
  }

  document.addEventListener('astro:page-load', initCreatorCarousel)
</script>
