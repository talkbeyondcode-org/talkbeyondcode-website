---
import Layout from '../layouts/Layout.astro'
import PageHeader from '../components/PageHeader.astro'
import Kicker from '../components/Kicker.astro'
import { creators, CONTACT_EMAIL } from '../data'

const SITE = 'https://talkbeyondcode.com'
const schema = creators.map((c) => ({
  '@type': 'Person',
  name: c.name,
  jobTitle: c.role,
  knowsAbout: c.talks,
  sameAs: [c.linkedin],
  worksFor: { '@id': `${SITE}/#organization` },
}))
---
<Layout
  title="Creators · TalkBeyondCode"
  description="The four engineers behind TalkBeyondCode. Different companies, stacks and career stages, one shared conversation about building software in the age of AI."
  schema={schema}
>
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-20">
    <PageHeader
      kicker="THE HUMANS"
      title="Four engineers, one mic"
      intro="We ship software at different companies, on different stacks, at different career stages. That friction is the whole point: same question, four very different answers."
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        creators.map((c) => (
          <article class="flex flex-col gap-5 rounded-[20px] border border-line bg-bg p-7 shadow-[var(--shadow-card)] md:p-8">
            <div class="flex items-center gap-4">
              <img
                src={c.photo}
                alt={c.name}
                loading="lazy"
                width="56"
                height="56"
                class="h-14 w-14 shrink-0 rounded-full border border-line object-cover"
              />
              <div>
                <h2 class="text-xl font-bold tracking-tight text-ink">{c.name}</h2>
                <p class="mt-0.5 text-sm text-muted">{c.role}</p>
              </div>
            </div>
            <p class="text-sm leading-relaxed text-muted">{c.bio}</p>
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-muted">Stack</span>
                <div class="mt-2.5 flex flex-wrap gap-2">
                  {c.stack.map((t) => (
                    <span class="rounded-full border border-line bg-bg px-3 py-1 font-mono text-xs text-ink">{t}</span>
                  ))}
                </div>
              </div>
              <div>
                <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-muted">Talks about</span>
                <div class="mt-2.5 flex flex-wrap gap-2">
                  {c.talks.map((t) => (
                    <span class="rounded-full border border-line bg-bg px-3 py-1 font-mono text-xs text-ink">{t}</span>
                  ))}
                </div>
              </div>
            </div>
            <div class="mt-auto border-t border-line pt-4">
              <a
                href={c.linkedin}
                target="_blank"
                rel="noreferrer"
                class="font-mono text-xs font-bold uppercase tracking-[0.1em] text-primary transition-colors hover:text-primary-deep"
              >
                LinkedIn →
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <section class="mt-20 grid items-center gap-10 rounded-[24px] border border-line bg-surface p-8 md:grid-cols-[1.3fr_1fr] md:p-12">
      <div>
        <Kicker>WHY WE STARTED</Kicker>
        <h2 class="mt-4 text-[clamp(1.8rem,4vw,2.6rem)] font-bold leading-tight tracking-tight text-ink">
          Code was never the whole story
        </h2>
        <p class="mt-5 max-w-[60ch] text-muted">
          The four of us kept having the same conversation after standups, the one about
          the decisions, trade-offs and career turns that never make it into commit
          messages. TalkBeyondCode is that conversation, recorded. Ctrl+Shift+AI is its
          first series: how engineers like us actually work with AI, beyond the demos.
        </p>
      </div>
      <div class="flex aspect-[4/3] items-center justify-center rounded-[16px] border border-dashed border-line bg-bg font-mono text-xs uppercase tracking-[0.16em] text-muted">
        [ group photo ]
      </div>
    </section>

    <section class="mt-8 flex flex-col items-start justify-between gap-6 rounded-[24px] border border-line bg-bg p-8 shadow-[var(--shadow-card)] sm:flex-row sm:items-center md:p-10">
      <h2 class="max-w-md text-xl font-bold tracking-tight text-ink">
        Want us on your podcast, or want to collaborate?
      </h2>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="shrink-0 rounded-full bg-primary px-6 py-3 font-mono text-[0.8rem] font-bold uppercase tracking-[0.1em] text-white transition-transform hover:-translate-y-0.5 hover:bg-primary-deep"
      >
        {CONTACT_EMAIL}
      </a>
    </section>
  </div>
</Layout>
