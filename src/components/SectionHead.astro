---
import Kicker from './Kicker.astro'

interface Props {
  kicker: string
  title: string
  href?: string
  hrefLabel?: string
}
const { kicker, title, href, hrefLabel } = Astro.props
---
<div class="flex flex-wrap items-end justify-between gap-4">
  <div>
    <Kicker>{kicker}</Kicker>
    <h2 class="mt-3 text-[clamp(1.7rem,3.4vw,2.5rem)] font-bold tracking-tight text-ink">
      {title}
    </h2>
  </div>
  {
    href && (
      <a
        href={href}
        class="font-mono text-xs font-bold uppercase tracking-[0.1em] text-primary transition-colors hover:text-primary-deep"
      >
        {hrefLabel} →
      </a>
    )
  }
</div>
