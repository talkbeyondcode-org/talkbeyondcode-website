---
import '../index.css'
import { ClientRouter } from 'astro:transitions'
import BaseHead from '../components/BaseHead.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
  noindex?: boolean
  ogImage?: string
  ogType?: 'website' | 'article'
  schema?: Record<string, unknown>[]
}

const { title, description, noindex, ogImage, ogType, schema } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      noindex={noindex}
      ogImage={ogImage}
      ogType={ogType}
      schema={schema}
    />
    <ClientRouter />
  </head>
  <body>
    <div class="flex min-h-svh flex-col">
      <Navbar />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
